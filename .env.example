# Copy values from Azure App Service → Configuration → Application settings.
# Canonical Adobe Commerce (ACCS) names — see includes/adobe-commerce-settings.php.

# Required
ADOBE_COMMERCE_CLIENT_ID=
ADOBE_COMMERCE_CLIENT_SECRET=

# stage | dev | production (default: stage)
ADOBE_COMMERCE_ENVIRONMENT=stage

# Optional tenant overrides (code defaults apply when unset)
# ADOBE_COMMERCE_TENANT_ID=
# ADOBE_COMMERCE_STAGE=
# ADOBE_COMMERCE_DEV=
ADOBE_COMMERCE_PRODUCTION=VLuKe3eeTwf1D5oxmLBfcr

# Optional advanced settings
# ADOBE_COMMERCE_API_HOST=
# ADOBE_COMMERCE_IMS_TOKEN_URL=
# ADOBE_COMMERCE_ORG_ID=
# ADOBE_COMMERCE_PAGE_SIZE=10
# ADOBE_COMMERCE_ORDERS_PAGE_SIZE=100
# ADOBE_COMMERCE_INVENTORY_PAGE_SIZE=100
# ADOBE_COMMERCE_WEBHOOK_SECRET=

# QuickBooks Online (Operations web app — production company connection)
# QBO_ENVIRONMENT=production
# QBO_CLIENT_ID_PROD=
# QBO_CLIENT_SECRET_PROD=
# QBO_REDIRECT_URI=https://nutraaxisweb.azurewebsites.net/accounting/callback.php
# QBO_SKU_ITEM_TYPE=NonInventory
# NonInventory (default) for Essentials — no qty tracking in QBO. Set Inventory for Plus/Advanced.
# QBO_DEFAULT_SERVICE_ITEM_SKU=SVC-PROFESSIONAL
# Catalog SKU code for non-inventory PO lines synced to QuickBooks when line items have no product SKU.
#
# Sandbox keys (test / function app only — shows sandbox companies, not live QBO)
# QBO_ENVIRONMENT=sandbox
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# Azure Blob Storage (required for portal file attachments)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=portal-attachments

# Provider signup (public onboarding + ops review)
# 32+ character secret for AES-256-GCM encryption of tax ID and ACH account numbers
PROVIDER_SIGNUP_ENCRYPTION_KEY=
# Comma-separated ops inbox for new submissions and provider updates
PROVIDER_SIGNUP_OPS_EMAIL=
