# Copy values from Azure App Service → Configuration → Application settings.
# Canonical Adobe Commerce (ACCS) names — see includes/adobe-commerce-settings.php.

# Required
ADOBE_COMMERCE_CLIENT_ID=
ADOBE_COMMERCE_CLIENT_SECRET=

# stage | dev | production (default: stage)
ADOBE_COMMERCE_ENVIRONMENT=stage

# Optional tenant overrides (code defaults apply when unset)
# ADOBE_COMMERCE_TENANT_ID=
# ADOBE_COMMERCE_STAGE=
# ADOBE_COMMERCE_DEV=
ADOBE_COMMERCE_PRODUCTION=VLuKe3eeTwf1D5oxmLBfcr

# Optional advanced settings
# ADOBE_COMMERCE_API_HOST=
# ADOBE_COMMERCE_IMS_TOKEN_URL=
# ADOBE_COMMERCE_ORG_ID=
# ADOBE_COMMERCE_PAGE_SIZE=10
# ADOBE_COMMERCE_ORDERS_PAGE_SIZE=100
# ADOBE_COMMERCE_INVENTORY_PAGE_SIZE=100
# ADOBE_COMMERCE_WEBHOOK_SECRET=

# Provider signup (public onboarding + ops review)
# PROVIDER_SIGNUP_ENCRYPTION_KEY=  # 32-byte key for encrypting tax ID and ACH account numbers
# PROVIDER_SIGNUP_OPS_EMAIL=NutraAxis@nfcllc.com  # Silent internal inbox when a new application starts
# PROVIDER_ACCS_LOGIN_URL=https://www.nutraaxislabs.com  # Link in provisioned provider email
# PROVIDER_SIGNUP_ACCS_ENVIRONMENT=stage  # Only provision when ADOBE_COMMERCE_ENVIRONMENT matches
# PROVIDER_SIGNUP_ACCS_USER_GROUP_ID=4  # Practitioner shared catalog (default: 4)
# PROVIDER_SIGNUP_ACCS_WEBSITE_ID=1
# PROVIDER_SIGNUP_ACCS_DEFAULT_PASSWORD=  # Optional fixed password for stage testing; otherwise auto-generated
# ADOBE_COMMERCE_RECAPTCHA_SITE_KEY=  # Google API Website Key from ACCS Stores > Security > Google reCAPTCHA > reCAPTCHA v2 Invisible
# ADOBE_COMMERCE_RECAPTCHA_VERSION=v2  # v2 (default, matches ACCS "Create New Customer Account") or v3
# ADOBE_COMMERCE_RECAPTCHA_TOKEN=  # Optional server-side token override for automated testing only

# Jazz OMS — UAT (default when a page does not opt into production)
# JAZZ_DOMAIN=fbflurry-uat01
# JAZZ_BASE_URL=
# JAZZ_USERNAME=
# JAZZ_PASSWORD=
# JAZZ_TENANT_CODE=NUT

# Jazz OMS — production (used when pages call jazz_oms_use_environment('production'))
# JAZZ_DOMAIN_PROD=fbflurry
# JAZZ_BASE_URL_PROD=https://fbflurry.jazz-oms.com
# JAZZ_USERNAME_PROD=
# JAZZ_PASSWORD_PROD=
