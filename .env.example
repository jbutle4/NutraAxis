# Copy values from Azure App Service → Configuration → Application settings.
# Canonical Adobe Commerce (ACCS) names — see includes/adobe-commerce-settings.php.

# Required
ADOBE_COMMERCE_CLIENT_ID=
ADOBE_COMMERCE_CLIENT_SECRET=

# Portal page profile selects the Adobe tenant:
#   Production pages (default data profile) → always use production tenant
#   UAT twin pages ($dataProfile = 'uat') → stage (or ADOBE_COMMERCE_UAT_ENVIRONMENT)
# Do NOT flip Production cards by changing ADOBE_COMMERCE_ENVIRONMENT alone.
# ADOBE_COMMERCE_ENVIRONMENT is only a legacy fallback for UAT / provider-signup checks.
# ADOBE_COMMERCE_UAT_ENVIRONMENT=stage
# ADOBE_COMMERCE_PRODUCTION_ENVIRONMENT=production

# Optional tenant overrides (code defaults apply when unset)
# ADOBE_COMMERCE_TENANT_ID=
# ADOBE_COMMERCE_STAGE=
# ADOBE_COMMERCE_DEV=
ADOBE_COMMERCE_PRODUCTION=VLuKe3eeTwf1D5oxmLBfcr

# Optional advanced settings
# ADOBE_COMMERCE_API_HOST=
# ADOBE_COMMERCE_IMS_TOKEN_URL=
# ADOBE_COMMERCE_ORG_ID=
# ADOBE_COMMERCE_PAGE_SIZE=10
# ADOBE_COMMERCE_ORDERS_PAGE_SIZE=100
# ADOBE_COMMERCE_INVENTORY_PAGE_SIZE=100
# ADOBE_COMMERCE_WEBHOOK_SECRET=

# Jazz OMS — production pages default to production credentials; UAT twins use UAT keys.
# Legacy JAZZ_* keys are fallbacks when the prod/UAT-specific keys are empty.
# JAZZ_DOMAIN=
# JAZZ_USERNAME=
# JAZZ_PASSWORD=
# JAZZ_TENANT_CODE=
# JAZZ_DOMAIN_PROD=
# JAZZ_USERNAME_PROD=
# JAZZ_PASSWORD_PROD=
# JAZZ_UAT_DOMAIN=
# JAZZ_UAT_USERNAME=
# JAZZ_UAT_PASSWORD=
# JAZZ_BASE_URL=
# JAZZ_BASE_URL_PROD=
# JAZZ_UAT_BASE_URL=
# JAZZ_PAGE_SIZE=100

# QuickBooks Online — one OAuth company per App Service.
# Production App Service should set QBO_ENVIRONMENT=production (code default is sandbox).
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=
# QBO_ENVIRONMENT=sandbox

# Azure Blob Storage — required for all document uploads (COA, PO, catalog, legal, TE, receiving, provider signup).
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT=   # optional override when not in the connection string
# AZURE_STORAGE_CONTAINER=portal-attachments

# App-level AES-GCM for sensitive bytes (provider docs) and provider tax/ACH fields.
# Prefer FILE_CRYPTO_ENCRYPTION_KEY; PROVIDER_SIGNUP_ENCRYPTION_KEY remains supported (same key chain).
# FILE_CRYPTO_ENCRYPTION_KEY=
# PROVIDER_SIGNUP_ENCRYPTION_KEY=  # 32+ char secret; also used if FILE_CRYPTO_* unset

# Provider signup (public onboarding + ops review)
# PROVIDER_SIGNUP_OPS_EMAIL=NutraAxis@nfcllc.com  # Silent internal inbox when a new application starts
# PROVIDER_ACCS_LOGIN_URL=https://www.nutraaxislabs.com  # Link in provisioned provider email
# PROVIDER_SIGNUP_ACCS_ENVIRONMENT=stage  # Only provision when that Adobe env is active
# PROVIDER_SIGNUP_ACCS_USER_GROUP_ID=4  # Practitioner shared catalog (default: 4)
# PROVIDER_SIGNUP_ACCS_WEBSITE_ID=1
# PROVIDER_SIGNUP_ACCS_DEFAULT_PASSWORD=  # Optional fixed password for stage testing; otherwise auto-generated

# Jazz OMS — UAT (default when a page does not opt into production)
# JAZZ_DOMAIN=fbflurry-uat01
# JAZZ_BASE_URL=
# JAZZ_USERNAME=
# JAZZ_PASSWORD=
# JAZZ_TENANT_CODE=NUT

# Jazz OMS — production (used when pages call jazz_oms_use_environment('production'))
# JAZZ_DOMAIN_PROD=fbflurry
# JAZZ_BASE_URL_PROD=https://fbflurry.jazz-oms.com
# JAZZ_USERNAME_PROD=
# JAZZ_PASSWORD_PROD=

# QuickBooks Online
# QBO_ENVIRONMENT=production
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_CLIENT_ID_PROD=
# QBO_CLIENT_SECRET_PROD=
# QBO_REDIRECT_URI=
# QBO_INSERT_STUB=1

# Azure Blob Storage (supplier invoice / payment attachments)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_ACCOUNT_KEY=
# AZURE_STORAGE_CONTAINER=portal-attachments
