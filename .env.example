# Copy values from Azure App Service → Configuration → Application settings.
# Canonical Adobe Commerce (ACCS) names — see includes/adobe-commerce-settings.php.

# Required
ADOBE_COMMERCE_CLIENT_ID=
ADOBE_COMMERCE_CLIENT_SECRET=

# stage | dev | production (default: stage)
ADOBE_COMMERCE_ENVIRONMENT=stage

# Optional tenant overrides (code defaults apply when unset)
# ADOBE_COMMERCE_TENANT_ID=
# ADOBE_COMMERCE_STAGE=
# ADOBE_COMMERCE_DEV=
ADOBE_COMMERCE_PRODUCTION=VLuKe3eeTwf1D5oxmLBfcr

# Optional advanced settings
# ADOBE_COMMERCE_API_HOST=
# ADOBE_COMMERCE_IMS_TOKEN_URL=
# ADOBE_COMMERCE_ORG_ID=
# ADOBE_COMMERCE_PAGE_SIZE=10
# ADOBE_COMMERCE_ORDERS_PAGE_SIZE=100
# ADOBE_COMMERCE_INVENTORY_PAGE_SIZE=100
# ADOBE_COMMERCE_WEBHOOK_SECRET=

# Provider signup (public onboarding + ops review)
# PROVIDER_SIGNUP_ENCRYPTION_KEY=  # 32-byte key for encrypting tax ID and ACH account numbers
# PROVIDER_SIGNUP_OPS_EMAIL=NutraAxis@nfcllc.com  # Silent internal inbox when a new application starts
# PROVIDER_ACCS_LOGIN_URL=https://www.nutraaxislabs.com  # Link in provisioned provider email
